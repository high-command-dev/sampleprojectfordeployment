PORT=5000
NODE_ENV=development

MONGO_URI=your_mongodb_connection_string

# If your MongoDB password contains special characters like @ # $ % : / ? & =,
# URL-encode the password before placing it in MONGO_URI.
# Example: my@pass#123 -> my%40pass%23123

FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d
OTP_EXPIRES_IN_MINUTES=10

# Optional: leave these blank to disable OTP email sending during deployment.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Project Auth <your_email@gmail.com>"

# Optional Cloudinary settings.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret